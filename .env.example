# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=fx_trading

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=3600s

# ─── FX API ──────────────────────────────────────────────────────────────────
# Leave blank to use mock FX provider (safe for local development)
# Get a free key at https://www.exchangerate-api.com
FX_API_KEY=
FX_API_BASE_URL=https://v6.exchangeapi.com
FX_CACHE_TTL_SECONDS=300

# ─── Mail (Gmail SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=noreply@fxtrading.com

# ─── Wallet ──────────────────────────────────────────────────────────────────
# Default NGN balance seeded on wallet creation (set to 0 per spec)
INITIAL_NGN_BALANCE=0